root@eltex-practice2-pg1-v22:~# vi testAwkScript.awk
root@eltex-practice2-pg1-v22:~# cat testAwkScript.awk
BEGIN {
        FS = ":"
}

NR == FNR {
        infoGID[$3]=$1
        n=split($4,splitMassive,",")
        for(i=1;i<=n;i++){
                userGroups[splitMassive[i]]=userGroups[splitMassive[i]] "," $1
        }
        next
}
$7=="/usr/sbin/nologin"{
        if($1 in userGroups){
                listUserGroups=infoGID[$4] userGroups[$1]
        }
        else{
                listUserGroups=infoGID[$4]
        }
        print $3,$1,listUserGroups
}

