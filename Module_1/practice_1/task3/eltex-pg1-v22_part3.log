mkdir -p D1/D2/D3
touch D1/D2/file.txt
echo Cheburashka >> D1/D2/file.txt
ln -s ../file.txt D1/D2/D3/file_symlink.txt
ln D1/D2/file.txt D1/D2/D3/file_hardlink.txt
ls -l D1/D2/D3
mv D1/D2/file.txt D1/
ls -l D1/D2/D3
rm -r D1/D2
find / -type f -size +20M > "${USER}_part3_gt50M.log"
while read -r f; do du -h "$f"; done < "${USER}_part3_gt50M.log"
find / -type f -mtime -1
which find
file "$(which find)"
file /boot/initrd.img*
